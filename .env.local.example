# Supabase — copy this file to .env.local and fill in your project's values.
# Project URL and anon (public) key from: Supabase Dashboard → Project Settings → API.
# The anon key is safe to expose to the browser; Row Level Security protects data.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# --- Agent CLI (scripts/sb.mjs) only — NOT used by the browser app ---
# The service_role key bypasses Row Level Security. It is SECRET: never commit it,
# never prefix it with NEXT_PUBLIC_, and never expose it to the browser.
# Found at: Supabase Dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
# The email of the owner account in Supabase Auth — the CLI writes scenes for this user.
# (Alternatively set STORYBOARD_OWNER_USER_ID directly to skip the email lookup.)
STORYBOARD_OWNER_EMAIL=you@example.com
